{
    "dataRoles": [
        {
            "name": "mainValue",
            "kind": "Measure",
            "displayName": "Valor Principal",
            "description": "Medida principal exibida em destaque no cartao",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "timeSeries",
            "kind": "GroupingOrMeasure",
            "displayName": "Eixo de Tempo (Sparkline)",
            "description": "Campo de data ou categoria para o eixo X da sparkline"
        },
        {
            "name": "sparkValue",
            "kind": "Measure",
            "displayName": "Valor da Sparkline",
            "description": "Medida para os pontos da sparkline (padrao: mesmo que Valor Principal)",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "comparisonValue",
            "kind": "Measure",
            "displayName": "Valor de Comparacao",
            "description": "Valor base para calculo de variancia (mes anterior, AA, meta)",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "targetValue",
            "kind": "Measure",
            "displayName": "Meta",
            "description": "Meta ou threshold para barra de progresso e linha de referencia",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "categoryLabel",
            "kind": "Grouping",
            "displayName": "Categoria",
            "description": "Rotulo de contexto exibido acima do titulo"
        },
        {
            "name": "secondaryMeasure1",
            "kind": "Measure",
            "displayName": "KPI Secundario 1",
            "description": "Primeira medida secundaria - requer licenca Premium",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "secondaryMeasure2",
            "kind": "Measure",
            "displayName": "KPI Secundario 2",
            "description": "Segunda medida secundaria - requer licenca Premium",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "secondaryMeasure3",
            "kind": "Measure",
            "displayName": "KPI Secundario 3",
            "description": "Terceira medida secundaria - requer licenca Premium",
            "requiredTypes": [{ "numeric": true }]
        },
        {
            "name": "secondaryMeasure4",
            "kind": "Measure",
            "displayName": "KPI Secundario 4",
            "description": "Quarta medida secundaria - requer licenca Premium",
            "requiredTypes": [{ "numeric": true }]
        }
    ],
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "mainValue":         { "max": 1 },
                    "timeSeries":        { "max": 1 },
                    "sparkValue":        { "max": 1 },
                    "comparisonValue":   { "max": 1 },
                    "targetValue":       { "max": 1 },
                    "categoryLabel":     { "max": 1 },
                    "secondaryMeasure1": { "max": 1 },
                    "secondaryMeasure2": { "max": 1 },
                    "secondaryMeasure3": { "max": 1 },
                    "secondaryMeasure4": { "max": 1 }
                }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        { "for": { "in": "timeSeries" } },
                        { "bind": { "to": "categoryLabel" } }
                    ],
                    "dataReductionAlgorithm": { "top": { "count": 500 } }
                },
                "values": {
                    "select": [
                        { "bind": { "to": "mainValue" } },
                        { "bind": { "to": "sparkValue" } },
                        { "bind": { "to": "comparisonValue" } },
                        { "bind": { "to": "targetValue" } },
                        { "bind": { "to": "secondaryMeasure1" } },
                        { "bind": { "to": "secondaryMeasure2" } },
                        { "bind": { "to": "secondaryMeasure3" } },
                        { "bind": { "to": "secondaryMeasure4" } }
                    ]
                }
            }
        }
    ],
    "objects": {
        "layout": {
            "properties": {
                "layoutType": {
                    "type": { "enumeration": [
                        { "value": "standard", "displayName": "Standard" },
                        { "value": "compact", "displayName": "Compacto" },
                        { "value": "split", "displayName": "Split" }
